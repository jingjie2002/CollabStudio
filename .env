# =============================================================================
# CollabServer 环境配置
# =============================================================================
# ⚠️ 此文件包含敏感信息，请勿提交到版本控制！
# 请将此文件复制为 .env 并根据实际环境修改
# =============================================================================

# =============================================================================
# 🔐 安全配置（必须修改）
# =============================================================================

# JWT 密钥（必须设置！至少32字符的随机字符串）
# 生成方式: openssl rand -base64 32
JWT_SECRET=5dXDDJhu_3qK7Q4uQx_nGOZGxgO_MIeQKLiBZqoJX64=

# CORS 白名单（逗号分隔的域名列表）
# 生产环境必须设置为你的前端域名
# 示例: http://your-server-ip,http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://wails.localhost

# =============================================================================
# 服务配置
# =============================================================================

# 服务运行端口
PORT=8080

# 运行模式（release = 生产模式，启用严格 CORS）
# GIN_MODE=release

# 数据库文件名 (SQLite)
DB_NAME=collab.db

# Redis 连接地址（可选，用于高并发场景的缓存）
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=

# 局域网发现服务端口 (UDP)
DISCOVERY_PORT=9999

# 上传文件存储目录
UPLOAD_DIR=uploads

# 前端静态资源打包目录 (相对路径或绝对路径)
DIST_PATH=./dist

# =============================================================================
# 管理员配置
# =============================================================================
ADMIN_PASSWORD=M7AfoymYGZQUZ2M6TbonxjN0y_i5P786BRYfRddW9Uo=
