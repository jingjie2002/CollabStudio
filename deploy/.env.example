# CollabStudio 部署环境配置示例

# -----------------
# 1. 基础服务配置
# -----------------
# 运行端口，建议 8080，可配合 Nginx 反向代理
PORT=8080

# 前端静态资源挂载路径（相对或绝对均可，必须指向 /dist 目录）
DIST_PATH=./dist

# 数据库存储路径（自动生成）
DB_PATH=./collab.db


# -----------------
# 2. 安全与鉴权
# -----------------
# 【必填项】跨域白名单（CORS）。非常关键！
# 本服务器允许哪些域名的网页来请求 API。如果不配置，浏览器会拦截所有登录和聊天请求。
# 如果你是通过 IP 访问（例如 119.29.55.127 或带端口号），必须如实填入。
# 多个域名用逗号分隔，末尾不要带反斜杠：
CORS_ORIGINS=http://119.29.55.127,http://119.29.55.127:8080

# 【必填项】JWT 签名密钥。在生产环境中请随机生成 32 位以上字符串！
# 可使用指令生成：openssl rand -base64 32
JWT_SECRET=production_secret_key_change_me


# -----------------
# 3. AI 调用配置
# -----------------
# （这里仅需配置全局或系统的 AI Key，用户界面的个人设置权重更高）
# AI_API_URL=https://api.deepseek.com/v1
# AI_API_KEY=sk-xxxxxx
# AI_MODEL=deepseek-chat
